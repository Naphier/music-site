# S3 deployment target
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1

# Folder in the bucket where audio/image assets live
# Example: tracks or artist-assets/tracks
TRACKS_PREFIX=tracks

# Folder in the bucket where the static site is deployed
# For this project, keep this as "dev" to publish the dev stage at s3://<bucket>/dev/
DEPLOY_PREFIX=dev

# true/false controls whether app.js should load mock tracks when S3 is not configured
ENABLE_MOCK_MODE=false

# HTML fragment filename in repository root that gets injected into <header class="artist-header">
HEADER_CONTENT_FILE=headerContent.html
